<Window x:Class="SolarBatteryAssistant.Simulator.SearchFiles.SearchFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Search Files"
        Height="500" Width="850"
        MinHeight="350" MinWidth="580"
        WindowStartupLocation="CenterOwner">

    <DockPanel LastChildFill="True">

        <!-- Top toolbar: search box and refresh -->
        <ToolBar DockPanel.Dock="Top" Margin="4">
            <Label Content="Search:" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchBox" Width="260" VerticalAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter files by name or path"/>
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,2" Margin="4,0"
                    ToolTip="Re-scan application data directories for files"/>
            <Separator/>
            <TextBlock x:Name="CountLabel" VerticalAlignment="Center" Foreground="#555555"/>
        </ToolBar>

        <!-- Bottom: status and close -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0"
                           Text="Select files and drag them to another application."
                           VerticalAlignment="Center" Foreground="#555555"/>
                <Button Content="Close" Grid.Column="1"
                        Click="Close_Click" Padding="12,4" IsCancel="True"/>
            </Grid>
        </Border>

        <!-- File list — drag selected rows to copy files to other applications -->
        <ListView x:Name="FileList"
                  Margin="4"
                  SelectionMode="Extended"
                  ItemsSource="{Binding FilteredFiles}"
                  SelectionChanged="FileList_SelectionChanged"
                  PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="FileList_PreviewMouseMove">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name"     Width="220" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="Type"     Width="75"  DisplayMemberBinding="{Binding FileType}"/>
                    <GridViewColumn Header="Size"     Width="75"  DisplayMemberBinding="{Binding FileSize}"/>
                    <GridViewColumn Header="Modified" Width="140" DisplayMemberBinding="{Binding LastModified}"/>
                    <GridViewColumn Header="Path"     Width="270" DisplayMemberBinding="{Binding FilePath}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
