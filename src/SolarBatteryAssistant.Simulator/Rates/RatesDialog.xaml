<Window x:Class="SolarBatteryAssistant.Simulator.Rates.RatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Energy Rates"
        Height="780" Width="1050"
        MinHeight="550" MinWidth="750"
        WindowStartupLocation="CenterOwner">

    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
        <ToolBar DockPanel.Dock="Top" Margin="4">
            <Label Content="Saved Rates:" VerticalAlignment="Center"/>
            <ComboBox x:Name="SavedRatesCombo" Width="200" VerticalAlignment="Center"
                      ToolTip="Select a previously saved rate set"/>
            <Button Content="Load" Click="LoadSaved_Click" Padding="8,2" Margin="2,0"
                    ToolTip="Load the selected saved rate set"/>
            <Separator/>
            <Button Content="Load from File…" Click="LoadFromFile_Click" Padding="8,2" Margin="2,0"
                    ToolTip="Choose a rate-set JSON file from disk"/>
            <Separator/>
            <Button x:Name="GetTodaysRatesButton"
                    Content="Get Today's Rates" Click="GetTodaysRates_Click"
                    Padding="8,2" Margin="2,0" IsEnabled="False"
                    Background="#E3F2FD" BorderBrush="#2196F3"
                    ToolTip="Fetch today's rates from the currently connected price provider"/>
            <Separator/>
            <Label Content="Save as:" VerticalAlignment="Center"/>
            <TextBox x:Name="RateSetNameBox" Width="170" VerticalAlignment="Center"
                     ToolTip="Name for this rate set, e.g. '2024-01-15' or 'Winter Agile'"/>
            <Button Content="Save" Click="Save_Click" Padding="8,2" Margin="2,0"
                    ToolTip="Save the current rates under the given name"/>
        </ToolBar>

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0"
                           Text="Load or fetch rates to get started."
                           VerticalAlignment="Center" Foreground="#555555"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Use These Rates" x:Name="OkButton" Click="Ok_Click"
                            Padding="12,4" Margin="4,0"
                            Background="#E8F5E9" BorderBrush="#4CAF50"
                            ToolTip="Use the current rates for all subsequent simulations"/>
                    <Button Content="Cancel" Click="Cancel_Click"
                            Padding="12,4" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: chart on top, editable grid below -->
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="260"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Price chart -->
            <GroupBox Header="Energy Prices (p/kWh)" Grid.Row="0" Margin="2">
                <lvc:CartesianChart x:Name="PriceChart" Hoverable="False" DataTooltip="{x:Null}">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Time Slot" Labels="{Binding SlotLabels}"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="p/kWh" MinValue="0"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </GroupBox>

            <!-- Resizer -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5"
                          Background="#CCCCCC" ShowsPreview="True"/>

            <!-- Editable DataGrid -->
            <GroupBox Header="Rate Slots — edit Import and Export prices directly in the grid"
                      Grid.Row="2" Margin="2">
                <DataGrid x:Name="RatesGrid"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          RowEditEnding="RatesGrid_RowEditEnding"
                          VirtualizingPanel.IsVirtualizing="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Slot" Binding="{Binding TimeLabel}"
                                            Width="55" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Import (p/kWh)"
                                            Binding="{Binding ImportPenceText, UpdateSourceTrigger=LostFocus}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Export (p/kWh)"
                                            Binding="{Binding ExportPenceText, UpdateSourceTrigger=LostFocus}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

    </DockPanel>
</Window>
