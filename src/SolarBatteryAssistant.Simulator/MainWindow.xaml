<Window x:Class="SolarBatteryAssistant.Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Solar Battery Assistant Simulator"
        Height="800" Width="1300"
        MinHeight="600" MinWidth="1000">

    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
        <ToolBar DockPanel.Dock="Top" Margin="4">
            <Label Content="Date:" VerticalAlignment="Center"/>
            <DatePicker x:Name="DateSelector" SelectedDateChanged="DateSelector_SelectedDateChanged"
                        VerticalAlignment="Center" Width="130"/>
            <Separator/>
            <Button Content="Load Plan" Click="LoadPlan_Click" Padding="8,2"/>
            <Button Content="Simulate Day" Click="SimulateDay_Click" Padding="8,2" Margin="4,0"/>
            <Separator/>
            <Button Content="Edit Rates…" Click="EditRates_Click" Padding="8,2"
                    ToolTip="Open the Rates dialog to get, visualise, edit and save import/export rates, then use them for simulation"/>
            <Separator/>

            <!-- Demo mode section -->
            <Label Content="Demo:" VerticalAlignment="Center"/>
            <Label Content="Battery:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoBatteryBox" Width="45" VerticalAlignment="Center" Text="50"
                     ToolTip="Starting battery SoC % for demo mode"/>
            <Label Content="%" VerticalAlignment="Center"/>
            <Label Content="Solar kWh:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoSolarBox" Width="55" VerticalAlignment="Center" Text="20"
                     ToolTip="Peak daily solar (kWh) for demo mode"/>
            <Label Content="Daily Load kWh:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoDailyLoadBox" Width="45" VerticalAlignment="Center" Text="8"
                     ToolTip="Estimated total house energy use per day in kWh (default 8 kWh)"/>
            <Label Content="Constant W:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoConstantLoadBox" Width="45" VerticalAlignment="Center" Text="100"
                     ToolTip="Always-on baseline load in Watts added to every slot (fridges, routers, standby devices). Default 100 W."/>
            <Label Content="Cheap ≤" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoCheapThresholdBox" Width="35" VerticalAlignment="Center" Text="2"
                     ToolTip="Import price threshold in p/kWh — slots at or below this always trigger charging (catches negative / near-zero prices)"/>
            <Label Content="p" VerticalAlignment="Center"/>
            <Label Content="Static Export p:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="DemoStaticExportBox" Width="40" VerticalAlignment="Center" Text=""
                     ToolTip="Fixed export rate in p/kWh (leave blank to use dynamic tariff export prices)"/>
            <CheckBox x:Name="DemoAllowExportBox" VerticalAlignment="Center" IsChecked="True"
                      Margin="4,0,0,0" ToolTip="Allow the planner to export to grid">Export</CheckBox>
            <CheckBox x:Name="DemoAllowGridChargingBox" VerticalAlignment="Center" IsChecked="True"
                      Margin="4,0,0,0" ToolTip="Allow the planner to import from grid to charge battery">Grid Charge</CheckBox>
            <Button x:Name="DemoModeButton" Content="▶ Demo Mode" Click="DemoMode_Click"
                    Padding="8,2" Margin="4,0"
                    Background="#E8F5E9" BorderBrush="#4CAF50"
                    ToolTip="Generate a plan using built-in example data — no HA connection needed"/>
            <Separator/>

            <!-- Live HA section -->
            <Label Content="HA URL:" VerticalAlignment="Center"/>
            <TextBox x:Name="HaUrlBox" Width="190" VerticalAlignment="Center" Text="http://homeassistant.local:8123"/>
            <Label Content="Token:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <PasswordBox x:Name="HaTokenBox" Width="140" VerticalAlignment="Center"/>
            <Label Content="Octopus Key:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <PasswordBox x:Name="OctopusApiKeyBox" Width="120" VerticalAlignment="Center"
                         ToolTip="Octopus Energy API key — required for auto-discovering product codes from your account"/>
            <Label Content="Account:" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBox x:Name="OctopusAccountBox" Width="100" VerticalAlignment="Center"
                     ToolTip="Octopus Energy account number (e.g. A-B1C2D3EF) — leave blank to use manually configured product codes"/>
            <Button Content="Connect HA" Click="Connect_Click" Padding="8,2" Margin="4,0"
                    ToolTip="Connect to live HomeAssistant"/>
            <Separator/>

            <!-- Local daemon section -->
            <Label Content="Daemon:" VerticalAlignment="Center"/>
            <TextBox x:Name="DaemonUrlBox" Width="160" VerticalAlignment="Center" Text="http://localhost:5100"
                     ToolTip="URL of locally-running SolarBatteryAssistant daemon"/>
            <Button Content="Connect Daemon" Click="ConnectDaemon_Click" Padding="8,2" Margin="4,0"
                    ToolTip="Connect to a local daemon for live plans and battery state"/>
            <Separator/>

            <TextBlock x:Name="StatusLabel" Text="Offline" VerticalAlignment="Center"
                       Foreground="Gray" Margin="4,0" FontWeight="SemiBold"/>
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="FooterLabel" Text="Ready — use Demo Mode to get started without any connections."/>
        </StatusBar>

        <!-- Main content -->
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Charts -->
            <TabControl Grid.Column="0" Margin="0,0,4,0">

                <!-- Day Plan Tab -->
                <TabItem Header="Day Plan">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Price chart -->
                        <GroupBox Header="Energy Prices (p/kWh)" Grid.Row="0" Margin="4">
                            <lvc:CartesianChart x:Name="PriceChart" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Time Slot" Labels="{Binding SlotLabels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="p/kWh" MinValue="0"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </GroupBox>

                        <!-- Battery &amp; Action chart -->
                        <GroupBox Header="Battery State of Charge (%)" Grid.Row="1" Margin="4">
                            <lvc:CartesianChart x:Name="BatteryChart" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Time Slot" Labels="{Binding SlotLabels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="%" MinValue="0" MaxValue="100"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- Simulation Tab -->
                <TabItem Header="Simulation Log">
                    <TextBox x:Name="SimulationLog" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                             Background="#1E1E1E" Foreground="#D4D4D4"/>
                </TabItem>

                <!-- History Tab -->
                <TabItem Header="History">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="HistoryDates" Grid.Row="0" Height="80"
                                 SelectionChanged="HistoryDate_SelectionChanged"/>
                        <DataGrid x:Name="HistoryGrid" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Slot" Binding="{Binding SlotStart, StringFormat=HH:mm}" Width="60"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="180"/>
                                <DataGridTextColumn Header="SoC Start" Binding="{Binding BatteryChargePercentStart, StringFormat=F0}" Width="70"/>
                                <DataGridTextColumn Header="SoC End" Binding="{Binding BatteryChargePercentEnd, StringFormat=F0}" Width="70"/>
                                <DataGridTextColumn Header="Est. Cost (p)" Binding="{Binding EstimatedCostPence, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Act. Cost (p)" Binding="{Binding ActualCostPence, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Solar (W)" Binding="{Binding SolarWatts, StringFormat=F0}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Right: Plan details panel -->
            <GroupBox Grid.Column="1" Header="Current Plan Summary" Margin="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <TextBlock Text="Plan Date:" FontWeight="Bold"/>
                        <TextBlock x:Name="PlanDateLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Generated:" FontWeight="Bold"/>
                        <TextBlock x:Name="GeneratedLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Battery SoC:" FontWeight="Bold"/>
                        <TextBlock x:Name="BatterySocLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Solar Forecast:" FontWeight="Bold"/>
                        <TextBlock x:Name="SolarForecastLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Est. Total Cost:" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalCostLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Action Schedule:" FontWeight="Bold" Margin="0,4,0,2"/>
                        <DataGrid x:Name="SlotGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  MaxHeight="400" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding SlotStart, StringFormat=HH:mm}" Width="45"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding ActionShort}" Width="*"/>
                                <DataGridTextColumn Header="SoC%" Binding="{Binding BatteryChargePercentEnd, StringFormat=F0}" Width="40"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
