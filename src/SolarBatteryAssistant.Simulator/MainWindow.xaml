<Window x:Class="SolarBatteryAssistant.Simulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Solar Battery Assistant Simulator"
        Height="800" Width="1300"
        MinHeight="600" MinWidth="1000">

    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
    <!-- Toolbar controls moved into a dedicated TabItem inside the left TabControl -->

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="FooterLabel" Text="Ready — use Demo Mode to get started without any connections."/>
        </StatusBar>

        <!-- Main content -->
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Charts -->
            <TabControl Grid.Column="0" Margin="0,0,4,0">

                <!-- Controls Tab (moved from top toolbar) -->
                <TabItem Header="Controls">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" Orientation="Vertical" Width="Auto">

                            <!-- General actions -->
                            <GroupBox Header="General" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Label Content="Date:" VerticalAlignment="Center"/>
                                        <DatePicker x:Name="DateSelector" SelectedDateChanged="DateSelector_SelectedDateChanged"
                                                    VerticalAlignment="Center" Width="130"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Load Plan" Click="LoadPlan_Click" Padding="8,4" Margin="0,0,6,0"/>
                                        <Button Content="Simulate Day" Click="SimulateDay_Click" Padding="8,4" Margin="0,0,6,0"/>
                                        <Button Content="Edit Rates…" Click="EditRates_Click" Padding="8,4" Margin="0,0,6,0"/>
                                        <Button Content="Search Files…" Click="SearchFiles_Click" Padding="8,4"
                                                ToolTip="Search plan and rate-set files — select and drag them to other applications"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <!-- Demo controls -->
                            <GroupBox Header="Demo Mode" Margin="0,0,0,8">
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="Battery:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="DemoBatteryBox" Width="45" Text="50" ToolTip="Starting battery SoC % for demo mode"/>
                                    <Label Grid.Row="0" Grid.Column="2" Content="Solar kWh:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="3" x:Name="DemoSolarBox" Width="80" Text="20" ToolTip="Peak daily solar (kWh) for demo mode"/>
                                    <Label Grid.Row="0" Grid.Column="4" Content="Daily Load kWh:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="5" x:Name="DemoDailyLoadBox" Width="80" Text="8" ToolTip="Estimated total house energy use per day in kWh (default 8 kWh)"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Constant W:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="DemoConstantLoadBox" Width="80" Text="100" ToolTip="Always-on baseline load in Watts added to every slot"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="Cheap ≤ (p):" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="DemoCheapThresholdBox" Width="80" Text="2"/>
                                    <Label Grid.Row="1" Grid.Column="4" Content="Static Export p:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="5" x:Name="DemoStaticExportBox" Width="80"/>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox x:Name="DemoAllowExportBox" IsChecked="True" Margin="0,0,8,0">Export</CheckBox>
                                        <CheckBox x:Name="DemoAllowGridChargingBox" IsChecked="True" Margin="0,0,8,0">Grid Charge</CheckBox>
                                        <Button x:Name="DemoModeButton" Content="▶ Demo Mode" Click="DemoMode_Click" Padding="8,4" Background="#E8F5E9" BorderBrush="#4CAF50"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <!-- Home Assistant / Octopus -->
                            <GroupBox Header="Home Assistant / Octopus" Margin="0,0,0,8">
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="HA URL:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="HaUrlBox" Width="300" Text="http://homeassistant.local:8123"/>
                                    <Label Grid.Row="0" Grid.Column="2" Content="Token:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <PasswordBox Grid.Row="0" Grid.Column="3" x:Name="HaTokenBox" Width="220"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="Octopus Key:" VerticalAlignment="Center"/>
                                    <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="OctopusApiKeyBox" Width="220" ToolTip="Octopus Energy API key — required for auto-discovering product codes from your account"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="Account:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="OctopusAccountBox" Width="160" ToolTip="Octopus Energy account number (e.g. A-B1C2D3EF)"/>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="Connect HA" Click="Connect_Click" Padding="8,4"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <!-- Local daemon -->
                            <GroupBox Header="Local Daemon" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="6">
                                    <Label Content="Daemon URL:" VerticalAlignment="Center"/>
                                    <TextBox x:Name="DaemonUrlBox" Width="260" VerticalAlignment="Center" Text="http://localhost:5100"/>
                                    <Button Content="Connect Daemon" Click="ConnectDaemon_Click" Padding="8,4" Margin="8,0,0,0"/>
                                    <Button x:Name="ClearPlansButton" Content="Clear Plans" Click="ClearPlans_Click" Padding="8,4" Margin="8,0,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Status -->
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock x:Name="StatusLabel" Text="Offline" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Day Plan Tab -->
                <TabItem Header="Day Plan">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Price chart -->
                        <GroupBox Header="Energy Prices (p/kWh)" Grid.Row="0" Margin="4">
                            <lvc:CartesianChart x:Name="PriceChart" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Time Slot" Labels="{Binding SlotLabels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="p/kWh" MinValue="0"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </GroupBox>

                        <!-- Battery &amp; Action chart -->
                        <GroupBox Header="Battery State of Charge (%)" Grid.Row="1" Margin="4">
                            <lvc:CartesianChart x:Name="BatteryChart" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Time Slot" Labels="{Binding SlotLabels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="%" MinValue="0" MaxValue="100"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- Simulation Tab -->
                <TabItem Header="Simulation Log">
                    <TextBox x:Name="SimulationLog" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                             Background="#1E1E1E" Foreground="#D4D4D4"/>
                </TabItem>

                <!-- History Tab -->
                <TabItem Header="History">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="HistoryDates" Grid.Row="0" Height="80"
                                 SelectionChanged="HistoryDate_SelectionChanged"/>
                        <DataGrid x:Name="HistoryGrid" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Slot" Binding="{Binding SlotStart, StringFormat=HH:mm}" Width="60"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="180"/>
                                <DataGridTextColumn Header="SoC Start" Binding="{Binding BatteryChargePercentStart, StringFormat=F0}" Width="70"/>
                                <DataGridTextColumn Header="SoC End" Binding="{Binding BatteryChargePercentEnd, StringFormat=F0}" Width="70"/>
                                <DataGridTextColumn Header="Est. Cost (p)" Binding="{Binding EstimatedCostPence, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Act. Cost (p)" Binding="{Binding ActualCostPence, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Solar (W)" Binding="{Binding SolarWatts, StringFormat=F0}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Right: Plan details panel -->
            <GroupBox Grid.Column="1" Header="Current Plan Summary" Margin="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <TextBlock Text="Plan Date:" FontWeight="Bold"/>
                        <TextBlock x:Name="PlanDateLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Generated:" FontWeight="Bold"/>
                        <TextBlock x:Name="GeneratedLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Battery SoC:" FontWeight="Bold"/>
                        <TextBlock x:Name="BatterySocLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Solar Forecast:" FontWeight="Bold"/>
                        <TextBlock x:Name="SolarForecastLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Est. Total Cost:" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalCostLabel" Text="-"/>
                        <Separator Margin="0,4"/>

                        <TextBlock Text="Action Schedule:" FontWeight="Bold" Margin="0,4,0,2"/>
                        <DataGrid x:Name="SlotGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  MaxHeight="400" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding SlotStart, StringFormat=HH:mm}" Width="45"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding ActionShort}" Width="*"/>
                                <DataGridTextColumn Header="SoC%" Binding="{Binding BatteryChargePercentEnd, StringFormat=F0}" Width="40"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
