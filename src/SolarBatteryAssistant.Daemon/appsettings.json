{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Urls": "http://localhost:5100",
  "SolarBatteryAssistant": {
    "HomeAssistant": {
      "BaseUrl": "http://homeassistant.local:8123",
      "AccessToken": "YOUR_LONG_LIVED_ACCESS_TOKEN",
      "SceneEntityIds": {
        "ImportFromGrid": "scene.import_from_grid",
        "ExportToGrid": "scene.export_to_grid",
        "BypassBatteryOnlyUseGrid": "scene.bypass_battery_only_use_grid",
        "NormalBatteryMinimiseGrid": "scene.normal_battery_minimise_grid"
      },
      "TimeoutSeconds": 30
    },
    "Battery": {
      "SocEntityId": "sensor.battery_state_of_charge",
      "CapacityWh": 10000,
      "MaxImportWatts": 3000,
      "MaxExportWatts": 3000,
      "MinChargePercent": 10,
      "MaxChargePercent": 100,
      "RoundTripEfficiency": 0.9,
      "EstimatedHouseLoadWatts": 500,
      "EstimatedDailyLoadWh": 8000,
      "ConstantLoadWatts": 100,
      "LoadActiveStartHour": 9,
      "LoadActiveEndHour": 21,
      "LoadActiveProportion": 0.80,
      "HouseLoadEntityId": null
    },
    "Solar": {
      "Mode": "HomeAssistantEntity",
      "ForecastEntityId": "sensor.solar_forecast_today",
      "ForecastAvailableTime": "06:00:00",
      "ScaleFactor": 0.7,
      "SolarNoon": "13:00:00",
      "ProductionHours": 8.0
    },
    "EnergyPricing": {
      "Provider": "OctopusAgile",
      "Octopus": {
        // Put in secrects.json instead of here in appsettings.json
        //https://octopus.energy/dashboard/new/accounts/personal-details/api-access
        //https://octopus.energy/dashboard/new/accounts/
        //"ApiKey": null,
        //"AccountNumber": null,
        "RegionCode": "C",
        "ImportProductCode": null,
        "ExportProductCode": null,
        "BaseUrl": "https://api.octopus.energy",
        "CacheDays": 2,
        "EnableUnitRateCaching": true
      }
    },
    "Planning": {
      "ReEvaluationIntervalMinutes": 30,
      "BatteryDeviationThresholdPercent": 10.0,
      "MinSavingToChangePence": 5.0,
      "EodTargetChargePercent": 20,
      "AllowExport": true,
      "AllowGridCharging": true,
      "VeryCheapImportThresholdPence": 2.0,
      "StaticExportPencePerKwh": null,
      "TimeZoneId": "Europe/London",
      // -----------------------------------------------------------------------
      // Bruteforce planner options
      // Set UseBruteForce to true to use the DP-based optimal planner instead
      // of the default greedy planner.
      // -----------------------------------------------------------------------
      "UseBruteForce": false,
      // Override the starting battery % for the bruteforce planner.
      // null = use the live HomeAssistant reading.
      "BruteForceStartingBatteryPercent": null,
      // Override the forecasted daily solar generation in Wh.
      // null = use the live forecast from the configured provider.
      "ForecastedSolarWh": null,
      // Path to a 24-row CSV of hourly solar percentage weights (no header).
      // null = use the built-in bell-curve distribution centred on SolarNoon.
      "SolarHourlyProfileCsvPath": null,
      // Path to a 24-row CSV of hourly extra house load in Watts (no header).
      // If the file does not exist an example is created automatically.
      // null = no extra load applied.
      "ExtraLoadCsvPath": "./data/extra_load_profile.csv",
      // Import unit-rate threshold (pence/kWh) below which the planner treats
      // the slot as a "sell stored energy, then recharge cheaply" opportunity.
      "ExportBatterySellThresholdPence": 5.0
    },
    "Storage": {
      "DataDirectory": "./data/plans",
      "RetentionDays": 90
    }
  }
}
